{
  "functions": {
    "api/gemini-proxy.js": {
      "maxDuration": 60,
      "memory": 1024,
      "regions": ["hnd1"]
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "picspark.cn" }],
      "destination": "https://www.picspark.cn/:path*",
      "permanent": false
    }
  ],
  "rewrites": [
    { "source": "/api/((?!gemini-proxy).*)", "destination": "http://101.32.186.47/staging-api/$1" },
    { "source": "/uploads/:path*", "destination": "http://101.32.186.47/staging-uploads/:path*" },
    { "source": "/((?!api/|uploads/|assets/|favicon\\.png|robots\\.txt|sitemap\\.xml).*)", "destination": "/index.html" }
  ]
}
