{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "picspark.cn" }],
      "destination": "https://www.picspark.cn/:path*",
      "permanent": false
    }
  ],
  "rewrites": [
    { "source": "/((?!api/|assets/|favicon\\.png|robots\\.txt|sitemap\\.xml).*)", "destination": "/index.html" }
  ]
}
