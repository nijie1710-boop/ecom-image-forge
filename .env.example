# ============================================================
# ecom-image-forge 环境变量示例
# 复制本文件为 .env.local（本地开发）或在 Vercel 项目设置里配置（生产）
# ============================================================

# ------------------------------------------------------------
# 前端（Vite）变量：以 VITE_ 前缀暴露到浏览器
# ------------------------------------------------------------
# Supabase 项目 URL
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase 客户端公开 key（publishable key / anon key）
# 可在 Supabase Dashboard → Project Settings → API 找到
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxx

# App origin for non-browser fallback paths. Configure separately per environment.
VITE_APP_URL=https://your-app-domain.example

# ------------------------------------------------------------
# 服务端（Vercel Serverless Functions）变量
# 注意：以下变量 **不要** 加 VITE_ 前缀，避免泄露到浏览器
# ------------------------------------------------------------

# Supabase 服务端 URL（通常与 VITE_SUPABASE_URL 相同）
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase 客户端公开 key（与 VITE_SUPABASE_PUBLISHABLE_KEY 相同）
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase 服务角色密钥（仅服务端使用，拥有完整数据库权限）
# 绝对不能暴露到前端；请谨慎保管
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Server-side app origin and CORS allow-list. Configure Preview/Staging with preview/staging domains.
APP_URL=https://your-app-domain.example
ALLOWED_ORIGINS=https://your-app-domain.example,https://your-preview-domain.example

# ------------------------------------------------------------
# 支付宝电脑网站支付
# ------------------------------------------------------------

# 支付宝应用 ID
ALIPAY_APP_ID=2021xxxxxxxxxxxx

# 支付宝应用私钥（PKCS8 PEM 格式，单行时用 \n 分隔换行；建议在 Vercel 里直接贴多行）
ALIPAY_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----

# 支付宝公钥（应用公钥对应的支付宝公钥，用于验签）
ALIPAY_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nMIIB...\n-----END PUBLIC KEY-----

# 支付宝网关地址（沙箱或生产）
# 生产：https://openapi.alipay.com/gateway.do
# 沙箱：https://openapi.alipaydev.com/gateway.do
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do

# 支付宝异步回调地址（必须是公网可达 HTTPS）
ALIPAY_NOTIFY_URL=https://your-app-domain.example/api/alipay-notify

# 用户支付完成后跳转回的页面
ALIPAY_RETURN_URL=https://your-app-domain.example/dashboard/recharge
